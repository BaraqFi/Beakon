# committed, shows required keys
# Server
PORT=5000
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/beakon
JWT_SECRET=<random 256-bit string>
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:3000
SERVER_URL=http://localhost:5000
NODE_ENV=development
IP2LOCATION_KEY=your_ip2location_api_key_here

# Production example (Beakon deployment):
# CLIENT_URL=https://beakn.lol
# SERVER_URL=https://api.beakn.lol

# Client
REACT_APP_API_URL=http://localhost:5000

# Production client (Vercel):
# REACT_APP_API_URL=https://api.beakn.lol